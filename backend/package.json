{
  "name": "edu-genie-backend",
  "version": "0.1.0",
  "description": "EduGenie backend prototype (Nest-like minimal scaffold)",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "mock-llm": "node mock_llm/server.js",
    "mock-tts": "node mock_tts/server.js",
    "dev": "npm run start:dev",
    "dev:full": "concurrently \"npm run mock-llm\" \"npm run start:dev\"",
    "dev:full:voice": "concurrently \"npm run mock-llm\" \"npm run mock-tts\" \"npm run start:dev\"",
    "smoke:rls-api": "bash scripts/rls_api_smoke.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "pg": "^8.9.0",
    "express": "^4.18.2",
    "node-fetch": "^3.0.0",
    "pdf-parse": "^1.1.1",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "dotenv": "^16.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^18.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "concurrently": "^8.0.0"
  }
}
